    "extract_numbers": true,
    "extract_lines": true
  },
  ".md": {
    "strip_blank_lines": false,
    "normalize_whitespace": true,
    "extract_numbers": true,
    "extract_headers": true,
    "extract_lines": true
  },
  ".py": {
    "strip_comments": true,
    "strip_blank_lines": true,
    "normalize_whitespace": true,
    "extract_numbers": true,
    "extract_functions": true
  },
  ".gd": {
    "strip_comments": true,
    "strip_blank_lines": true,
